# Hyperliquid read-only live account display
# Use your real main account or sub-account address, not an API/agent wallet.
HYPERLIQUID_USER_ADDRESS=0x
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
# Extra Hyperliquid HIP-3 perp dex names to read, comma-separated.
# The app also reads the default perp market automatically.
HYPERLIQUID_PERP_DEXS=xyz

# Existing Deribit credentials, kept only while Deribit code is still present
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Feedback widget email delivery via Resend (https://resend.com, free tier).
# Sign up with the receiving mailbox, create an API key, paste it below.
RESEND_API_KEY=
# Mailbox that receives feedback submissions.
FEEDBACK_TO=pnlnotes@gmail.com
