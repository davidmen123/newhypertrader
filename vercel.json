{
  "installCommand": "corepack pnpm install --no-frozen-lockfile",
  "buildCommand": "corepack pnpm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/trpc/[...trpc].ts": {
      "runtime": "@vercel/node@3.2.0",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
